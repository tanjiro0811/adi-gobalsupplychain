# Application Setup
APP_ENV=development
APP_NAME=Global Supply Chain API
SECRET_KEY=change-me-in-env

# Security & JWT Tokens
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BLOCKCHAIN_SALT=global-supply-chain-salt

# Rate Limiting
# Rate limit for login and OTP endpoints to prevent brute force
RATE_LIMIT_AUTH=5/minute

# Database Configuration
# Local development stays on SQLite; use Postgres in production only if needed.
DATABASE_URL=sqlite:///./local.db
SQLITE_DB_PATH=local.db

# External Services
# GEMINI API key unlocks Gemini-powered AI forecasts (fallback baselines apply when blank).
GEMINI_API_KEY=

# Email Settings
# Set to true to print emails to console instead of sending.
# For real delivery, keep this false and set SMTP + SENDER_PASSWORD (Gmail requires an App Password).
MOCK_EMAIL_DELIVERY=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=noreply@globalsupplychain.local
SENDER_PASSWORD=
SENDER_NAME=Global Supply Chain
