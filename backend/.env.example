# Application Setup
APP_ENV=development
APP_NAME=Global Supply Chain API
SECRET_KEY=change-me-in-env

# Security & JWT Tokens
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BLOCKCHAIN_SALT=global-supply-chain-salt

# Rate Limiting
# Rate limit for login and OTP endpoints to prevent brute force
RATE_LIMIT_AUTH=5/minute

# Database Configuration
# When using Docker Compose, use this PostgreSQL URL:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/global_supply_chain
DATABASE_URL=
SQLITE_DB_PATH=data/app.db

# External Services
GEMINI_API_KEY=

# Email Settings
MOCK_EMAIL_DELIVERY=true
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=noreply@globalsupplychain.local
SENDER_PASSWORD=
SENDER_NAME=Global Supply Chain
