# Application Setup
APP_ENV=development
APP_NAME=Global Supply Chain API
SECRET_KEY=change-me-in-env
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Security & JWT Tokens
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BLOCKCHAIN_SALT=global-supply-chain-salt


RATE_LIMIT_AUTH=5/minute


DATABASE_URL=sqlite:///./local.db
SQLITE_DB_PATH=local.db


ANTHROPIC_API_KEY=
# Optional: override the Claude model (default is claude-opus-4-6).
ANTHROPIC_MODEL=claude-opus-4-6

# Optional: use Gemini instead of Claude (or set AI_PROVIDER=auto and provide one key).
AI_PROVIDER=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Email Settings
# Set to true to print emails to console instead of sending.
# For real delivery, keep this false and set SMTP + SENDER_PASSWORD (Gmail requires an App Password).
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=noreply@globalsupplychain.local
SENDER_PASSWORD=
SENDER_NAME=Global Supply Chain
