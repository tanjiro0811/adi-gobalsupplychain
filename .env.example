ANTHROPIC_API_KEY=sk-ant-your-new-key-here
ANTHROPIC_MODEL=claude-opus-4-6

# Optional: AI provider selection (auto | anthropic | gemini)
AI_PROVIDER=auto

# Optional: Google Gemini (works when GEMINI_API_KEY is set; for backward compatibility, a Gemini key in ANTHROPIC_API_KEY also works in auto mode)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
