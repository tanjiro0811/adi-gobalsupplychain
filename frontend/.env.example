# This frontend uses Vite environment variables, so production values must use the VITE_ prefix.
VITE_API_BASE_URL=/api
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
VITE_ENABLE_DEMO_FALLBACK=false
# Render production example:
# VITE_API_BASE_URL=https://your-backend.onrender.com/api
# VITE_GPS_SOCKET_URL=wss://your-backend.onrender.com/ws/gps
# VITE_SOCKET_BASE_URL=https://your-backend.onrender.com
# Optional custom socket base:
# VITE_GPS_SOCKET_URL=ws://127.0.0.1:8000/ws/gps
# VITE_SOCKET_BASE_URL=ws://127.0.0.1:8000
# VITE_NOTIFICATION_SOCKET_BASE_URL=ws://127.0.0.1:8000
